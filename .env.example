# ───────────────────────────────────────────────────────────
# GarageOS — variables d'environnement
# Copie ce fichier en `.env` et remplis les valeurs réelles.
# Ne commit JAMAIS le fichier .env (déjà ignoré par .gitignore).
# ───────────────────────────────────────────────────────────

# Email (Gmail SMTP)
GMAIL_USER=
GMAIL_PASSWORD=

# SMS (Brevo)
BREVO_API_KEY=
BREVO_SMS_FROM=GarageMtgn

# Paiement (Stripe)
# Mode test : sk_test_… / Mode live : sk_live_…
STRIPE_SECRET_KEY=
# Secret de signature du webhook (commence par whsec_…)
STRIPE_WEBHOOK_SECRET=

# CORS — domaines autorisés, séparés par des virgules
CORS_ORIGINS=https://garagedelamontagne.fr,https://www.garagedelamontagne.fr

# ⚠️ DEV / BETA UNIQUEMENT — désactive complètement l'authentification.
# Quand activé, toute requête est traitée comme provenant du 1er admin.
# NE JAMAIS laisser à true en production avec de vrais clients connectés.
DISABLE_AUTH=false
